# Developer Dockerfile for React + Vite Frontend
FROM node:22-alpine

# Set working directory
WORKDIR /app

# Ensure we have permissions for node_modules and cache folders
RUN mkdir -p /app/node_modules && chown -R node:node /app

# Copy dependency manifest files first to optimize Docker layer caching
COPY --chown=node:node package.json package-lock.json ./

# Switch to non-root user 'node' before installing dependencies
USER node

# Install dependencies
RUN npm ci

# Copy the rest of the source files with correct owner permissions
COPY --chown=node:node . .

# Expose Vite default dev server port
EXPOSE 5173

# Start Vite dev server in host mode for hot reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
